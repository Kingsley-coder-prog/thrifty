# ─────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─────────────────────────────────────────────
# Environment variables — NEVER commit these
# ─────────────────────────────────────────────
.env
.env.local
.env.development
.env.staging
.env.production
.env.test

# ─────────────────────────────────────────────
# Cryptographic keys — NEVER commit these
# ─────────────────────────────────────────────
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# ─────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────
dist/
build/
.output/
.nuxt/
.next/

# ─────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pino.log*

# ─────────────────────────────────────────────
# Test coverage
# ─────────────────────────────────────────────
coverage/
.nyc_output/

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ─────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# ─────────────────────────────────────────────
# Editors and IDEs
# ─────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Keep shared editor config (formatting rules etc.)
!.vscode/extensions.json
!.editorconfig

# ─────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────
# keep docker-compose.yml but ignore override files
docker-compose.override.yml

# ─────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────
.cache/
.temp/
tmp/