# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,https://app.thrifty.ng

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://thrifty_app:password@localhost:5432/thrifty_dev

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# JWT — RS256 asymmetric keys
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste values as single-line with \n
# ─────────────────────────────────────────────
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─────────────────────────────────────────────
# Encryption — AES-256-GCM
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes)
# ─────────────────────────────────────────────
ENCRYPTION_KEY=your_64_char_hex_string_here

# ─────────────────────────────────────────────
# Paystack
# ─────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here

# ─────────────────────────────────────────────
# Mono (account balance checks before debit)
# ─────────────────────────────────────────────
MONO_SECRET_KEY=your_mono_secret_key

# ─────────────────────────────────────────────
# BVN verification — via licensed aggregator
# Options: Dojah (dojah.io), Smile ID, Prembly
# ─────────────────────────────────────────────
BVN_PROVIDER_KEY=your_bvn_provider_key
BVN_PROVIDER_URL=https://api.dojah.io

# ─────────────────────────────────────────────
# SMS — Termii
# ─────────────────────────────────────────────
TERMII_API_KEY=your_termii_key
TERMII_SENDER_ID=Thrifty

# ─────────────────────────────────────────────
# Admin console — separate JWT secret
# ─────────────────────────────────────────────
ADMIN_JWT_SECRET=separate_long_random_secret_for_admin_tokens
