{
  "name": "thrifty-api",
  "version": "0.1.0",
  "description": "Thrifty cooperative savings platform API",
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env src/server.js",
    "start": "node --env-file=.env src/server.js",
    "worker": "node --env-file=.env src/worker.js",
    "migrate": "node --env-file=.env node_modules/.bin/knex migrate:latest",
    "migrate:rollback": "node --env-file=.env node_modules/.bin/knex migrate:rollback",
    "seed": "node --env-file=.env node_modules/.bin/knex seed:run",
    "test": "node --env-file=.env --experimental-vm-modules node_modules/.bin/jest",
    "test:unit": "node --env-file=.env node_modules/.bin/jest test/unit",
    "test:integration": "node --env-file=.env node_modules/.bin/jest test/integration"
  },
  "dependencies": {
    "argon2": "^0.31.2",
    "axios": "^1.6.0",
    "bullmq": "^4.15.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "node-cron": "^3.0.3",
    "otplib": "^12.0.1",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-pretty": "^13.1.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "testcontainers": "^10.4.0"
  }
}
